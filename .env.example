# Forge Testnet Bot — Configuration
# Copy to .env and fill in your keys

# Required: 2captcha API key for solving reCAPTCHA
2CAPTCHA_API_KEY=

# Bot behavior
LOOP_INTERVAL=3600          # Seconds between full loops (default: 1h)
FAUCET_COOLDOWN=86400       # Seconds between faucet claims per wallet (24h)
WALLET_COUNT=3              # Wallets to auto-generate at startup
