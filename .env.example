# 2captcha API key — untuk solve reCAPTCHA taoswap faucet
2CAPTCHA_API_KEY=place_your_api_key_here
#
# Wallet config (JSON array, harus 1 baris)
# Format: [{"pk":"0x...","sub_mnemonic":"... mnemonic ..."}, ...]
#   pk:           EVM private key (REQUIRED)
#   sub_mnemonic: Substrate mnemonic (OPTIONAL — untuk bridge native TAO ke EVM)
#   ss58:         SS58 address (OPTIONAL — untuk faucet kalo sub_mnemonic gak ada)
#
# Contoh:
#   WALLETS=[{"pk":"0xabc123...","sub_mnemonic":"abandon amount ability..."}]
#   WALLETS=[{"pk":"0xabc...","ss58":"5Fzt..."}]
#   WALLETS=[{"pk":"0xabc..."},{"pk":"0xdef..."}]
WALLETS=
